CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_redmi-router-ax6000-ubootlayout=y
CONFIG_KERNEL_VERSION="6.12"

# homeproxy-hiddify
CONFIG_PACKAGE_luci-app-homeproxy-hiddify=y
CONFIG_PACKAGE_hiddify-core=y
CONFIG_PACKAGE_homeproxy-geodata=y
CONFIG_PACKAGE_homeproxy-tproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y

# 依赖
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-netfilter-tproxy=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_https-dns-proxy=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# 优化
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_WIFI_HARDWARE_OFFLOAD=y

# 隐藏信息
CONFIG_HIDE_BUILD_INFO=y
CONFIG_HIDE_VERSION_INFO=y
CONFIG_IMAGE_HOSTNAME="ImmortalWrt"
